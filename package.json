{
  "name": "pocket-gym",
  "version": "1.0.0",
  "private": true,
  "description": "Palestre in Zona is a SvelteKit web app for discovering nearby gyms and martial arts clubs.",
  "type": "module",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js dev",
    "build": "bun ./node_modules/@sveltejs/kit/svelte-kit.js sync && bun ./node_modules/vite/bin/vite.js build",
    "prepare": "bun ./node_modules/@sveltejs/kit/svelte-kit.js sync",
    "preview": "bun ./node_modules/vite/bin/vite.js preview",
    "check": "bun run scripts/check-stock-assets.mjs && bun run scripts/check-copy-slop.mjs && bun run scripts/check-visible-mojibake.mjs && bun run scripts/check-data-quality.mjs && bun ./node_modules/@sveltejs/kit/svelte-kit.js sync && bun ./node_modules/svelte-check/bin/svelte-check --tsconfig ./jsconfig.json",
    "check:stock": "bun run scripts/check-stock-assets.mjs",
    "check:copy": "bun run scripts/check-copy-slop.mjs",
    "check:text": "bun run scripts/check-visible-mojibake.mjs",
    "check:data": "bun run scripts/check-data-quality.mjs",
    "db:check:enrichment": "bun scripts/check-supabase-enrichment-schema.mjs --env-file=.env.vercel.production.check",
    "db:staging:preflight": "bun scripts/check-supabase-staging-readiness.mjs --env-file=.env.staging.local",
    "vercel:preview:staging-env": "bun scripts/set-vercel-preview-envs.mjs --staging-env-file=.env.staging.local --token-env-file=.env.vercel.local",
    "vercel:preview:status": "bun scripts/vercel-preview-status.mjs --token-env-file=.env.vercel.local",
    "enrichment:report": "bun scripts/report-gym-content-enrichment.mjs --env-file=.env.vercel.production.check",
    "enrichment:sync-overrides": "bun scripts/sync-official-overrides-enrichment.mjs --env-file=.env.vercel.production.check",
    "enrichment:sync-batch": "bun scripts/sync-reviewed-enrichment-batch.mjs --env-file=.env.vercel.production.check",
    "editorial:audit": "bun scripts/audit-editorial-descriptions.ts --env-file=.env.staging.local",
    "editorial:generate:dry": "bun scripts/generate-editorial-descriptions.ts --mode=dry-run --env-file=.env.staging.local",
    "editorial:apply": "bun scripts/generate-editorial-descriptions.ts --mode=apply --env-file=.env.staging.local",
    "editorial:verify": "bun scripts/verify-editorial-descriptions.ts --env-file=.env.staging.local",
    "editorial:publish:candidates": "bun scripts/publish-editorial-candidates.ts --env-file=.env.staging.local",
    "prices:reassign:dry": "bun scripts/preview-price-reassignment.ts --env-file=.env.staging.local",
    "prices:reassign:apply": "bun scripts/apply-price-reassignment.ts --env-file=.env.staging.local",
    "prices:review:queue": "bun scripts/report-price-review-queue.ts",
    "prices:enrichment:candidates": "bun scripts/report-price-enrichment-candidates.ts --env-file=.env.staging.local",
    "prices:discover:official": "bun scripts/discover-official-price-pages.ts",
    "prices:enrich:dry": "bun scripts/generate-price-enrichment-preview.ts --env-file=.env.staging.local",
    "content:enrich:dry": "bun scripts/generate-content-enrichment-preview.ts --env-file=.env.staging.local",
    "official:reconcile:one": "bun scripts/official-reconcile-one.mjs --env-file=.env.staging.local",
    "official:editorial:dry": "bun scripts/official-editorial-dry.mjs --env-file=.env.staging.local",
    "descriptions:audit": "bun scripts/audit-descriptions.ts --env-file=.env.staging.local",
    "descriptions:repair:dry": "bun scripts/preview-description-repairs.ts",
    "descriptions:levels:apply": "bun scripts/apply-description-levels-preview.ts --env-file=.env.staging.local",
    "descriptions:generate:dry": "bun scripts/generate-gym-descriptions.ts --mode=dry-run --env-file=.env.staging.local",
    "descriptions:apply": "bun scripts/generate-gym-descriptions.ts --mode=apply --env-file=.env.staging.local",
    "audit:gyms:contamination": "bun scripts/audit-gym-contamination.ts --env-file=.env.staging.local",
    "audit:gyms:contamination:preview": "bun scripts/fix-gym-contamination-preview.ts --env-file=.env.staging.local",
    "audit:gyms:contamination:apply": "bun scripts/apply-gym-contamination-fixes.ts --env-file=.env.staging.local",
    "seo:legacy-redirects": "bun scripts/report-legacy-gym-redirects.mjs",
    "seo:check:sitemap": "bun scripts/check-sitemap-no-legacy-urls.mjs",
    "seo:check:archived": "bun scripts/check-archived-gym-urls.mjs",
    "seo:check:legacy": "bun scripts/check-legacy-gym-redirects.mjs",
    "seo:check:archived-csv-drift": "bun scripts/check-archived-public-csv-drift.mjs",
    "clean:data": "bun run scripts/clean-data-control-chars.mjs",
    "sync:gyms:staging": "bun scripts/sync-supabase-gyms.mjs --env-file=.env.staging.local",
    "sync:gyms:prod": "bun scripts/sync-supabase-gyms.mjs --env-file=.env.vercel.production.check"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.17.1",
    "@tailwindcss/vite": "^4.0.9",
    "svelte": "^5.19.5",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.9",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1"
  }
}
