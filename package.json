{
  "name": "pocket-gym",
  "version": "1.0.0",
  "private": true,
  "description": "Palestre in Zona is a SvelteKit web app for discovering nearby gyms and martial arts clubs.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "check": "bun run scripts/check-stock-assets.mjs && bun run scripts/check-copy-slop.mjs && bun run scripts/check-visible-mojibake.mjs && bun run scripts/check-data-quality.mjs && bun ./node_modules/@sveltejs/kit/svelte-kit.js sync && bun ./node_modules/svelte-check/bin/svelte-check --tsconfig ./jsconfig.json",
    "check:stock": "bun run scripts/check-stock-assets.mjs",
    "check:copy": "bun run scripts/check-copy-slop.mjs",
    "check:text": "bun run scripts/check-visible-mojibake.mjs",
    "check:data": "bun run scripts/check-data-quality.mjs",
    "db:check:enrichment": "bun scripts/check-supabase-enrichment-schema.mjs --env-file=.env.vercel.production.check",
    "db:staging:preflight": "bun scripts/check-supabase-staging-readiness.mjs --env-file=.env.staging.local",
    "vercel:preview:staging-env": "bun scripts/set-vercel-preview-envs.mjs --staging-env-file=.env.staging.local --token-env-file=.env.vercel.local",
    "vercel:preview:status": "bun scripts/vercel-preview-status.mjs --token-env-file=.env.vercel.local",
    "enrichment:report": "bun scripts/report-gym-content-enrichment.mjs --env-file=.env.vercel.production.check",
    "enrichment:sync-overrides": "bun scripts/sync-official-overrides-enrichment.mjs --env-file=.env.vercel.production.check",
    "enrichment:sync-batch": "bun scripts/sync-reviewed-enrichment-batch.mjs --env-file=.env.vercel.production.check",
    "descriptions:audit": "bun scripts/generate-gym-descriptions.ts --mode=audit --env-file=.env.staging.local",
    "descriptions:generate:dry": "bun scripts/generate-gym-descriptions.ts --mode=dry-run --env-file=.env.staging.local",
    "descriptions:apply": "bun scripts/generate-gym-descriptions.ts --mode=apply --env-file=.env.staging.local",
    "audit:gyms:contamination": "bun scripts/audit-gym-contamination.ts --env-file=.env.staging.local",
    "audit:gyms:contamination:preview": "bun scripts/fix-gym-contamination-preview.ts --env-file=.env.staging.local",
    "audit:gyms:contamination:apply": "bun scripts/apply-gym-contamination-fixes.ts --env-file=.env.staging.local",
    "seo:legacy-redirects": "bun scripts/report-legacy-gym-redirects.mjs",
    "clean:data": "bun run scripts/clean-data-control-chars.mjs",
    "sync:gyms:staging": "bun scripts/sync-supabase-gyms.mjs --env-file=.env.staging.local",
    "sync:gyms:prod": "bun scripts/sync-supabase-gyms.mjs --env-file=.env.vercel.production.check"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.17.1",
    "@tailwindcss/vite": "^4.0.9",
    "svelte": "^5.19.5",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.9",
    "vite": "^7.3.1"
  }
}

