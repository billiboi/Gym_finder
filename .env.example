# Public/runtime Supabase endpoint.
SUPABASE_URL=

# Server-side key used by admin/write flows. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional, defaults to gyms.
SUPABASE_GYMS_TABLE=gyms

# Set to staging in staging env files and production only in production.
SUPABASE_ENV=development

# Optional, defaults to claim_requests where supported by the code path.
SUPABASE_CLAIMS_TABLE=claim_requests

# Public contact address used by contact links and claim/update fallback emails.
SITE_CONTACT_EMAIL=info@palestreinzona.it

# Optional recipient for automatic claim/update notifications.
# If omitted, the app falls back to SITE_CONTACT_EMAIL.
CLAIM_NOTIFICATION_TO=info@palestreinzona.it
