# Public/runtime Supabase endpoint.
SUPABASE_URL=

# Server-side key used by admin/write flows. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional, defaults to gyms.
SUPABASE_GYMS_TABLE=gyms

# Optional, defaults to claim_requests where supported by the code path.
SUPABASE_CLAIMS_TABLE=claim_requests
